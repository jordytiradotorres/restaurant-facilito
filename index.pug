<!DOCTYPE html>
html(lang="es").no-js
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        meta(http-equiv="X-UA-Compatible", content="ie=edge")
        meta(name="description" content="Come rico y barato en el mejor restaurant de la ciudad, servicio de primera. Especialidad en pescados y mariscos")
        link(rel="stylesheet", href="./css/styles.css")
        title Restaurant facilito
    body
        .contenedor
            .video-container
                video(autoplay, loop, muted, width="1280" height="720" poster="./img/poster.jpg")
                    source(src="./video/video.mp4" type="video/mp4")
                    source(src="./video/video.webm" type="video/webm")
            div.container-title
                img(src="./img/logo.png", alt="logo", width="200")
                h1 Restaurant Facilito
                p
                    img(src="./img/clock.png" alt="reloj")
                    small Abierto ahora
            .footer-home
                - var pages = ['Inicio','Menu','Galeria','Contacto', 'Como llegar']
                nav.navigation.sticky
                    ul.navigation__ul
                        each page in pages
                            li.navigation__item
                                a(href=`#${page.toLowerCase().split(' ').join("-")}`).navigation__link.sticky= page
            |
            - var menu = [{nombre: 'Chocolate', image: 'chocolate', precio: '$50.00'}, {nombre: 'Pizza Peperoni', image: 'pizza', precio: '$100.00'}, {nombre: 'Burrito', image: 'burrito', precio: '$150.00'},  {nombre: 'Hamburger', image: 'hamburger', precio: '$80.00'},  {nombre: 'Espaguetis', image: 'espaguetis', precio: '$120.00'}, {nombre: 'Ceviche', image: 'ceviche', precio: '$30.00'}]
            .menu#menu
                each item in menu
                    figure.menu__figure
                        img.menu__img(src=`./img/${item.image}.jpg`, alt=`${item.nombre}`)
                        .menu__description
                            p= item.nombre
                            p= item.precio
                |
                .menu__float Menú
            |
            .gallery#galeria
                .inner
                    each image in menu
                        .gallery__image(style=`background-image: url(./img/${image.image}.jpg)`)
            |
            .card
                p.card__title En #[span RestauranteFacilito] cocinar no es una profesión, no es una técnica, es un #[span arte]
                p.card__subtitle
                    | Lorem ipsum dolor sit amet consectetur, adipisicing elit.  Lorem ipsum dolor sit amet consectetur, adipisicing elit. Et deserunt quod ullam laudantium molestiae consequuntur nihil quidem, modi sapiente beatae inventore dicta quos atque ab! Libero sapiente dignissimos temporibus natus. - #[span Coco - Chef]
            |
            .contact#contacto
                .wrapper-contact
                    .containerr
                        .front.side
                            .content
                                br
                                br
                                br
                                br
                                h1 3D Contact
                        .back.side
                            .content
                                h1 Contact Me
                                form#form(action="https://formspree.io/mbjdjlgz" method="POST")
                                    label Tu nombre:
                                    input(type="text" name="name" placeholder="Tu nombre")
                                    label Tu email:
                                    input(type="email" name="email" placeholder="example@gmail.com")
                                    label Tu mensaje
                                    textarea(placeholder="The mensaje" name="mensaje")
                                    input#send(type="submit" value="Enviar")
                                #status
            |
            #como-llegar
                #map
                #message Prueba
        script(src="https://maps.googleapis.com/maps/api/js?key=AIzaSyDnnvjAKeMdTCtJ3cp726k5kcmnjaJyCXI") // api de google maps
        script(src="./js/index.js")